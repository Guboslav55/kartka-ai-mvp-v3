# Supabase — отримай на supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI DALL-E — platform.openai.com → API Keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Wayforpay — особистий кабінет → Налаштування → Ключі
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_account
WAYFORPAY_MERCHANT_KEY=your_secret_key
NEXT_PUBLIC_WAYFORPAY_MERCHANT=your_merchant_account

# URL сайту (при деплої на Vercel змінити на реальний)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
